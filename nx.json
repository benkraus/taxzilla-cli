{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/**/*.spec.ts",
      "!{projectRoot}/**/*.test.ts",
      "!{projectRoot}/tsconfig.json"
    ],
    "sharedGlobals": ["{workspaceRoot}/.oxlintrc.json", "{workspaceRoot}/.oxfmtrc.json", "{workspaceRoot}/tsconfig.base.json"]
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["production", "^production"]
    },
    "typecheck": {
      "dependsOn": ["^build", "^typecheck"],
      "inputs": ["default", "^default"]
    },
    "lint": {
      "inputs": ["default", "{workspaceRoot}/.oxlintrc.json"]
    },
    "format": {
      "cache": false,
      "inputs": ["default", "{workspaceRoot}/.oxfmtrc.json"]
    },
    "dev": {
      "continuous": true,
      "cache": false
    }
  },
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "packages"
  },
  "defaultBase": "main"
}
