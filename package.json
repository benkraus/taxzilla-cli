{
  "name": "taxzilla-open",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.2.12",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "nx run-many -t build --all",
    "typecheck": "nx run-many -t typecheck --all",
    "lint": "nx run-many -t lint --all",
    "format": "nx run-many -t format --all",
    "dev": "bun run --cwd apps/cli dev",
    "cli": "bun run --cwd apps/cli src/index.tsx",
    "graph": "nx graph",
    "test": "vitest run",
    "test:coverage": "bun run --cwd packages/tax-engine test:coverage"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.2",
    "@vitest/coverage-v8": "3.2.4",
    "nx": "22.5.2",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "typescript": "5.9.3",
    "vitest": "3.2.4"
  }
}
