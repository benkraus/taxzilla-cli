{
  "name": "@taxzilla/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "taxzilla": "./src/index.tsx"
  },
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "build": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --root ../.. apps/cli/src/",
    "lint": "oxlint -c ../../.oxlintrc.json --deny-warnings .",
    "format": "oxfmt -c ../../.oxfmtrc.json ."
  },
  "dependencies": {
    "@opentui/core": "^0.1.87",
    "@opentui/react": "^0.1.87",
    "@taxzilla/tax-engine": "workspace:*",
    "effect": "^3.19.19",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "typescript": "^5.9.3",
    "vitest": "3.2.4"
  }
}
