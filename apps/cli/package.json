{
  "name": "@taxzilla/cli",
  "version": "0.2.0",
  "private": false,
  "description": "Bun-powered local-first CLI for the TaxZilla TY2025 federal tax engine.",
  "type": "module",
  "bin": {
    "taxzilla": "./src/index.tsx"
  },
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts",
    "!src/**/*.spec.tsx",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benkraus/taxzilla-cli.git",
    "directory": "apps/cli"
  },
  "homepage": "https://github.com/benkraus/taxzilla-cli#readme",
  "bugs": {
    "url": "https://github.com/benkraus/taxzilla-cli/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.2.12"
  },
  "scripts": {
    "dev": "bun run --watch src/index.tsx",
    "build": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --root ../.. apps/cli/src/",
    "lint": "oxlint -c ../../.oxlintrc.json --deny-warnings .",
    "format": "oxfmt -c ../../.oxfmtrc.json ."
  },
  "dependencies": {
    "@opentui/core": "^0.1.87",
    "@opentui/react": "^0.1.87",
    "@taxzilla/tax-engine": "^0.2.0",
    "effect": "^3.19.19",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "typescript": "^5.9.3",
    "vitest": "3.2.4"
  }
}
