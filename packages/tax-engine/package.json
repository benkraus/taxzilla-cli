{
  "name": "@taxzilla/tax-engine",
  "version": "0.1.0",
  "private": false,
  "description": "TY2025 tax engine and blueprint bundle used by TaxZilla CLI.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts",
    "!src/**/*.spec.tsx",
    "!src/**/*test-helpers.ts",
    "docs",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./return-ir": {
      "types": "./src/return-ir.ts",
      "default": "./src/return-ir.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benkraus/taxzilla-cli.git",
    "directory": "packages/tax-engine"
  },
  "homepage": "https://github.com/benkraus/taxzilla-cli#readme",
  "bugs": {
    "url": "https://github.com/benkraus/taxzilla-cli/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "bun": ">=1.2.12"
  },
  "scripts": {
    "build": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --root ../.. packages/tax-engine/src/",
    "test:coverage": "vitest run --root ../.. packages/tax-engine/src/ --coverage.enabled --coverage.provider=v8 --coverage.reporter=text --coverage.include=\"packages/tax-engine/src/**/*.ts\"",
    "lint": "oxlint -c ../../.oxlintrc.json --deny-warnings .",
    "format": "oxfmt -c ../../.oxfmtrc.json ."
  },
  "dependencies": {
    "effect": "^3.19.19"
  }
}
